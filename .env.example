# Copy this file to .env and export the variables in your shell before starting the app.
# The current dev scripts do not load .env automatically.

# Core runtime
SKYSORT_DATABASE_URL=sqlite:///var/data/skysort.db
SKYSORT_DATA_DIR=var/data
SKYSORT_CACHE_DIR=var/cache
SKYSORT_LOG_DIR=var/logs
SKYSORT_TMP_DIR=var/tmp
SKYSORT_EXIFTOOL_PATH=exiftool

# Local AI default (LM Studio)
SKYSORT_AI_PROVIDER=lm_studio
SKYSORT_AI_BASE_URL=http://127.0.0.1:1234/v1
SKYSORT_AI_MODEL_NAME=qwen2.5-vl-7b-instruct
SKYSORT_ALLOW_REMOTE_AI=false
SKYSORT_AI_TIMEOUT_SECONDS=10
SKYSORT_AI_CONCURRENCY=1
SKYSORT_IMAGE_PROCESSING_CONCURRENCY=2

# Optional OpenRouter settings
# Uncomment and adjust these when using a remote provider.
# SKYSORT_AI_PROVIDER=openrouter
# SKYSORT_AI_BASE_URL=https://openrouter.ai/api/v1
# SKYSORT_AI_MODEL_NAME=openai/gpt-5-nano
# SKYSORT_ALLOW_REMOTE_AI=true
# SKYSORT_AI_API_KEY=your_api_key
# SKYSORT_AI_REFERER=https://example.com/skysort
# SKYSORT_AI_TITLE=SkySort