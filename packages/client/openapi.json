  "components": {
    "schemas": {
      "AIHealthResponse": {
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "lm_studio",
              "openrouter"
            ],
            "title": "Provider"
          },
          "reachable": {
            "type": "boolean",
            "title": "Reachable"
          },
          "localhost_only": {
            "type": "boolean",
            "title": "Localhost Only"
          },
          "remote_allowed": {
            "type": "boolean",
            "title": "Remote Allowed"
          },
          "auth_configured": {
            "type": "boolean",
            "title": "Auth Configured"
          },
          "available_models": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Available Models"
          },
          "configured_model": {
            "type": "string",
            "title": "Configured Model"
          },
          "configured_model_exists": {
            "type": "boolean",
            "title": "Configured Model Exists"
          },
          "model_loadable": {
            "type": "boolean",
            "title": "Model Loadable"
          },
          "vision_capable": {
            "type": "boolean",
            "title": "Vision Capable"
          },
          "structured_json_capable": {
            "type": "boolean",
            "title": "Structured Json Capable"
          },
          "checked_at": {
            "type": "string",
            "title": "Checked At"
          },
          "error_detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Detail"
          }
        },
        "type": "object",
        "required": [
          "provider",
          "reachable",
          "localhost_only",
          "remote_allowed",
          "auth_configured",
          "available_models",
          "configured_model",
          "configured_model_exists",
          "model_loadable",
          "vision_capable",
          "structured_json_capable",
          "checked_at"
        ],
        "title": "AIHealthResponse"
      },
      "AnalyzeRequest": {
        "properties": {
          "reuse_cache": {
            "type": "boolean",
            "title": "Reuse Cache",
            "default": true
          }
        },
        "type": "object",
        "title": "AnalyzeRequest"
      },
      "BatchMutationRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "photo_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Photo Ids"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "photo_ids",
          "action"
        ],
        "title": "BatchMutationRequest"
      },
      "ExportResultsRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "format": {
            "type": "string",
            "title": "Format"
          },
          "filters": {
            "additionalProperties": true,
            "type": "object",
            "title": "Filters"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "format"
        ],
        "title": "ExportResultsRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ImportRequest": {
        "properties": {
          "root_path": {
            "type": "string",
            "title": "Root Path"
          },
          "recursive": {
            "type": "boolean",
            "title": "Recursive",
            "default": true
          },
          "file_types": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "File Types"
          },
          "reuse_cache": {
            "type": "boolean",
            "title": "Reuse Cache",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "root_path"
        ],
        "title": "ImportRequest"
      },
      "ImportResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "registered_count": {
            "type": "integer",
            "title": "Registered Count"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "registered_count"
        ],
        "title": "ImportResponse"
      },
      "JobProgressResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "total_files": {
            "type": "integer",
            "title": "Total Files"
          },
          "imported_files": {
            "type": "integer",
            "title": "Imported Files"
          },
          "grouped_files": {
            "type": "integer",
            "title": "Grouped Files"
          },
          "technically_scored_files": {
            "type": "integer",
            "title": "Technically Scored Files"
          },
          "semantically_scored_files": {
            "type": "integer",
            "title": "Semantically Scored Files"
          },
          "failed_files": {
            "type": "integer",
            "title": "Failed Files"
          },
          "provisional_rated_files": {
            "type": "integer",
            "title": "Provisional Rated Files"
          },
          "final_rated_files": {
            "type": "integer",
            "title": "Final Rated Files"
          },
          "current_stage": {
            "type": "string",
            "title": "Current Stage"
          },
          "errors": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Errors"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "finished_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finished At"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "total_files",
          "imported_files",
          "grouped_files",
          "technically_scored_files",
          "semantically_scored_files",
          "failed_files",
          "provisional_rated_files",
          "final_rated_files",
          "current_stage",
          "errors"
        ],
        "title": "JobProgressResponse"
      },
      "MutationResult": {
        "properties": {
          "updated_count": {
            "type": "integer",
            "title": "Updated Count"
          },
          "failed_count": {
            "type": "integer",
            "title": "Failed Count"
          }
        },
        "type": "object",
        "required": [
          "updated_count",
          "failed_count"
        ],
        "title": "MutationResult"
      },
      "PhotoMutationRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "rating": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 5.0,
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Rating"
          },
          "selection_status": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "normal",
                  "rejected"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Selection Status"
          },
          "pick_flag": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pick Flag"
          },
          "best_cut_flag": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
